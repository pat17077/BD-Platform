# Copy this file to .env and fill in your real keys. .env is gitignored.
# On Render, set these as Environment Variables in the dashboard instead.

# FRED economic data — get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Anthropic Claude — for the AI market-color synthesis. App works without this
# but blurbs will be empty. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Strong random token gating /api/internal/* — must match the constant in
# index.html (search for `const INTERNAL_TOKEN = '...'`). Generate with:
#   openssl rand -hex 32
INTERNAL_TOKEN=

# Optional override; Render injects PORT automatically.
# PORT=3001
